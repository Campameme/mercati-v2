# ——— Supabase ———
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...           # server-only

# Connection string Postgres del progetto Supabase (solo per `npm run migrate`,
# le migrazioni NON girano più in automatico né in build).
# Dashboard → Project Settings → Database → Connection string → URI
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.xxxx.supabase.co:5432/postgres

# ——— Sito ———
# URL pubblico del sito: usato per metadataBase, sitemap, robots, OG e link nelle email.
# In locale può restare vuoto (fallback: http://localhost:3000).
NEXT_PUBLIC_SITE_URL=

# ——— Meteo ———
NEXT_PUBLIC_WEATHER_API_KEY=                      # OpenWeatherMap

# ——— Email (form adesioni) ———
RESEND_API_KEY=                                   # server-only; senza chiave l'email si salta ma il DB salva
RESEND_FROM=Mercati di Ponente <no-reply@tuodominio.it>
ADESIONI_TO=                                      # destinatario delle richieste di adesione

# ——— Privacy ———
# OBBLIGATORIA in produzione: sale per l'hash degli IP (adesioni + analytics).
# Genera una stringa casuale lunga (es. `openssl rand -hex 32`).
IP_SALT=
